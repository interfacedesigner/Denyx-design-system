{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm build-storybook",
  "outputDirectory": "storybook-static",
  "functions": {
    "api/mcp.ts": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/mcp", "destination": "/api/mcp" }
  ]
}
